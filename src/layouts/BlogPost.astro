---
const { title, description, author, createdAt, tags, thumbnail } = Astro.props;
const formattedDate = new Date(createdAt).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {thumbnail && <meta property="og:image" content={thumbnail} />}
    <title>{title} | 셀러비즈 블로그</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #1a1a1a;
        line-height: 1.8;
        background: #fff;
      }
      header {
        border-bottom: 1px solid #eee;
        padding: 1rem 2rem;
      }
      header a {
        text-decoration: none;
        color: #1a1a1a;
        font-weight: 700;
        font-size: 1.1rem;
      }
      .hero-image {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
      }
      article {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }
      h1 {
        font-size: 2rem;
        line-height: 1.3;
        margin-bottom: 1rem;
      }
      .meta {
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #eee;
      }
      .tags { margin-top: 0.5rem; }
      .tag {
        display: inline-block;
        background: #f0f0f0;
        padding: 0.15rem 0.6rem;
        border-radius: 3px;
        font-size: 0.8rem;
        margin-right: 0.4rem;
        color: #555;
      }
      .content :global(h2) {
        font-size: 1.4rem;
        margin: 2.5rem 0 1rem;
        padding-top: 1rem;
      }
      .content :global(h3) {
        font-size: 1.15rem;
        margin: 2rem 0 0.8rem;
      }
      .content :global(p) { margin-bottom: 1.2rem; }
      .content :global(strong) { font-weight: 600; }
      .content :global(a) { color: #2563eb; }
      .content :global(blockquote) {
        border-left: 3px solid #2563eb;
        padding: 0.8rem 1.2rem;
        margin: 1.5rem 0;
        background: #f8f9fa;
        color: #444;
      }
      .content :global(hr) {
        border: none;
        border-top: 1px solid #eee;
        margin: 2rem 0;
      }
      footer {
        text-align: center;
        padding: 2rem;
        border-top: 1px solid #eee;
        color: #999;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/">셀러비즈 블로그</a>
    </header>
    {thumbnail && <img class="hero-image" src={thumbnail} alt={title} />}
    <article>
      <h1>{title}</h1>
      <div class="meta">
        <div>{author} · {formattedDate}</div>
        {tags && tags.length > 0 && (
          <div class="tags">
            {tags.map((tag: string) => <span class="tag">#{tag}</span>)}
          </div>
        )}
      </div>
      <div class="content">
        <slot />
      </div>
    </article>
    <footer>
      &copy; 2026 셀러비즈. All rights reserved.
    </footer>
  </body>
</html>
