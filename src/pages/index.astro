---
import { getCollection } from 'astro:content';

const articles = (await getCollection('article'))
  .sort((a, b) => new Date(b.data.createdAt).getTime() - new Date(a.data.createdAt).getTime());
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="셀러비즈 블로그 - 온라인 쇼핑몰 매매 인사이트" />
    <title>셀러비즈 블로그</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #1a1a1a;
        line-height: 1.6;
        background: #fff;
      }
      header {
        border-bottom: 1px solid #eee;
        padding: 1rem 2rem;
      }
      header h1 {
        font-size: 1.1rem;
        font-weight: 700;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      .article-list { list-style: none; }
      .article-item {
        padding: 1.5rem 0;
        border-bottom: 1px solid #f0f0f0;
      }
      .article-item:last-child { border-bottom: none; }
      .article-item a {
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .article-item a:hover h2 { color: #2563eb; }
      .article-item h2 {
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
        transition: color 0.15s;
      }
      .article-item p {
        color: #666;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
      }
      .article-meta {
        color: #999;
        font-size: 0.8rem;
      }
      .tag {
        display: inline-block;
        background: #f0f0f0;
        padding: 0.1rem 0.5rem;
        border-radius: 3px;
        font-size: 0.75rem;
        margin-left: 0.3rem;
        color: #555;
      }
      .empty {
        text-align: center;
        color: #999;
        padding: 4rem 0;
      }
      footer {
        text-align: center;
        padding: 2rem;
        border-top: 1px solid #eee;
        color: #999;
        font-size: 0.85rem;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>셀러비즈 블로그</h1>
    </header>
    <main>
      {articles.length === 0 ? (
        <div class="empty">아직 게시된 글이 없습니다.</div>
      ) : (
        <ul class="article-list">
          {articles.map((article) => (
            <li class="article-item">
              <a href={`/article/${article.id}`}>
                <h2>{article.data.title}</h2>
                <p>{article.data.description}</p>
                <div class="article-meta">
                  {article.data.author} · {new Date(article.data.createdAt).toLocaleDateString('ko-KR')}
                  {article.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <footer>
      &copy; 2026 셀러비즈. All rights reserved.
    </footer>
  </body>
</html>
